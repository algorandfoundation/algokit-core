# Example code to test MessagePack support

from {{packageName}} import (
    Configuration,
    ApiClient, 
    PendingTransactionsApi
)
from {{packageName}} import msgpack_handler


def test_pending_transactions_msgpack():
    """
    Test that the pending transactions endpoint can handle MessagePack format.
    This test requires msgpack support to be enabled.
    """
    if not msgpack_handler.supports_msgpack():
        print("MessagePack support is not available, skipping test")
        return
    
    # Initialize the API client with custom format
    configuration = Configuration()
    configuration.host = "http://localhost:4001"  # Your algod API endpoint
    configuration.api_key['X-Algo-API-Token'] = "your-api-token"
    
    # Create API client
    api_client = ApiClient(configuration)
    
    # Set Accept header to prefer MessagePack
    api_client.set_default_header('Accept', 'application/msgpack')
    
    # Create and initialize PendingTransactionsApi instance
    api_instance = PendingTransactionsApi(api_client)
    
    try:
        # Get pending transactions
        # When 'format' parameter is set to 'msgpack', it will be included in the URL
        # The server will return MessagePack encoded data if it supports it
        response = api_instance.get_pending_transactions(format='msgpack')
        
        # The response should be automatically decoded to the appropriate model type
        print(f"Successfully retrieved pending transactions with MessagePack format")
        print(f"Number of pending transactions: {len(response.top_transactions)}")
        
        # You can also convert the response back to MessagePack format
        # This is useful if you want to pass the data to another system that expects MessagePack
        if hasattr(response, 'to_msgpack'):
            msgpack_data = response.to_msgpack()
            print(f"Successfully converted response to MessagePack format: {len(msgpack_data)} bytes")
            
            # You can also convert it back to a model
            from_msgpack = response.__class__.from_msgpack(msgpack_data)
            print(f"Successfully converted MessagePack data back to model")
            
    except Exception as e:
        print(f"Exception when calling PendingTransactionsApi->get_pending_transactions: {e}")


if __name__ == "__main__":
    test_pending_transactions_msgpack() 
